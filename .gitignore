# --- PROTECT SECRETS ---
# Never push your database passwords or hash salts
web/sites/*/settings.php
web/sites/*/settings.local.php
web/sites/*/settings.ddev.php

# --- IGNORE JUNK & BULKY FILES ---
# No need to push the engine (Core) or dependencies (Vendor)
/vendor/
/web/core/

# --- IGNORE USER CONTENT ---
# This ignores uploaded images and local temp files
/web/sites/*/files/

# --- DDEV CONFIG ---
# Your local environment settings
.ddev/

/web/modules/contrib/
/web/themes/contrib/
web/sites/default/files/